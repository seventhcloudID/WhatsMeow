# Port HTTP server
PORT=8081

# API key untuk autentikasi (wajib di production)
API_KEY=your-secret-api-key

# Basis path DB. Foldernya dipakai untuk DB per tenant: data/sessions/<id>.db
DB_PATH=data/session.db

# URL webhook pesan masuk untuk session "default" (opsional).
# Tenant lain set webhook lewat: PUT /webhook + header X-Session-ID
WEBHOOK_URL=

# Level log: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
